@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@{
    var currentController = ViewContext.RouteData.Values["controller"] as string;
    string NavActive(string c) => string.Equals(currentController, c, StringComparison.OrdinalIgnoreCase)
        ? "nav-link nav-link-active" : "nav-link";
}
<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Pínówó</title>

    @* Tailwind is served locally (not from cdn.tailwindcss.com) so core layout
       never depends on a runtime CDN - a blocked/slow CDN was leaving the whole
       page unstyled. Same reasoning as the local SignalR client. *@
    <script src="~/lib/tailwind/tailwindcss.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        background: "#fff8f3", surface: "#fff8f3", "surface-low": "#f9f2ed",
                        "surface-container": "#f3ede7", white: "#ffffff",
                        "on-surface": "#1d1b18", "on-surface-variant": "#45474a",
                        outline: "#76777b", hairline: "#E8E3D8",
                        obsidian: "#0B0D10", primary: "#000000",
                        gold: "#C9A227", "gold-dim": "#A6851F",
                        "secondary-container": "#fed255", "on-secondary-container": "#735a00",
                        pos: "#2E7D32", "pos-bg": "#E8F5E9", neg: "#ba1a1a", "neg-bg": "#ffdad6",
                        btc: "#F7931A", usdt: "#26A17B"
                    },
                    fontFamily: { serif: ["Libre Caslon Text", "serif"], sans: ["Inter", "sans-serif"] },
                    maxWidth: { container: "1280px" },
                    boxShadow: { diffusion: "0 10px 30px rgba(11,13,16,0.05)" }
                }
            }
        };
    </script>
    <style>
        body { background:#fff8f3; color:#1d1b18; font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased; font-variant-numeric:tabular-nums; }
        .font-serif { font-family:'Libre Caslon Text', serif; }
        .hairline { border:1px solid #E8E3D8; }
        .card { background:#fff; border:1px solid #E8E3D8; border-radius:12px; box-shadow:0 10px 30px rgba(11,13,16,0.04); }
        .material-symbols-outlined { font-variation-settings:'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24; vertical-align:middle; line-height:1; }

        /* Nav */
        .nav-link { font-size:12px; font-weight:600; letter-spacing:.05em; color:#45474a; padding-bottom:2px; transition:color .2s; }
        .nav-link:hover { color:#755b00; }
        .nav-link-active { color:#1d1b18; border-bottom:2px solid #C9A227; }

        /* Buttons */
        .btn { display:inline-flex; align-items:center; justify-content:center; gap:.5rem; border-radius:12px; font-weight:600; font-size:12px; letter-spacing:.05em; text-transform:uppercase; padding:.75rem 1.5rem; cursor:pointer; transition:all .2s ease; border:1px solid transparent; text-decoration:none; white-space:nowrap; }
        .btn-sm { padding:.5rem 1rem; }
        .btn-obsidian { background:#0B0D10; color:#fff; }
        .btn-obsidian:hover { opacity:.9; }
        .btn-gold { background:#C9A227; color:#fff; }
        .btn-gold:hover { background:#A6851F; }
        .btn-outline { background:transparent; border-color:#E8E3D8; color:#1d1b18; }
        .btn-outline:hover { background:#f3ede7; }
        .btn-gold-outline { background:transparent; border:1px solid #C9A227; color:#C9A227; }
        .btn-gold-outline:hover { background:rgba(201,162,39,.06); }
        .btn-settle { background:transparent; border:1px solid #107C10; color:#107C10; padding:.5rem 1rem; }
        .btn-settle:hover { background:#107C10; color:#fff; }
        .btn-ghost { background:transparent; color:#45474a; text-transform:none; letter-spacing:normal; font-weight:500; border:none; padding:.5rem .75rem; }
        .btn-ghost:hover { color:#1d1b18; text-decoration:underline; text-underline-offset:4px; text-decoration-color:#C9A227; }

        /* Fields */
        .field-label { display:block; font-size:12px; font-weight:600; letter-spacing:.05em; text-transform:uppercase; color:#45474a; margin-bottom:.5rem; }
        /* Table header label: same look as .field-label but keeps table-cell display. */
        .th-label { font-size:12px; font-weight:600; letter-spacing:.05em; text-transform:uppercase; color:#45474a; }
        .field { width:100%; background:#FAF9F6; border:1px solid #E8E3D8; border-radius:8px; padding:.75rem 1rem; font-family:'Inter'; font-size:16px; color:#1d1b18; transition:all .2s; }
        .field:focus { outline:none; border-color:#C9A227; box-shadow:0 0 0 1px #C9A227; }
        select.field { appearance:none; -webkit-appearance:none; padding-right:2.5rem; cursor:pointer; }
        .select-wrap { position:relative; }
        .select-wrap .chevron { position:absolute; right:.85rem; top:50%; transform:translateY(-50%); pointer-events:none; color:#76777b; }
        .input-validation-error { border-color:#ba1a1a !important; box-shadow:0 0 0 1px rgba(186,26,26,.3); }
        .field-error, .field-validation-error { color:#ba1a1a; font-size:13px; margin-top:.35rem; display:inline-block; }
        .validation-summary-errors { background:#ffdad6; color:#93000a; border:1px solid rgba(186,26,26,.2); border-radius:8px; padding:.75rem 1rem; margin-bottom:1.25rem; font-size:14px; }
        .validation-summary-errors ul { margin:0; padding-left:1.1rem; }
        .validation-summary-valid { display:none; }

        /* Chips & badges */
        .chip { display:inline-flex; align-items:center; padding:2px 8px; border-radius:6px; font-size:10px; font-weight:700; letter-spacing:.02em; text-transform:uppercase; }
        .chip-btc { background:rgba(247,147,26,.12); color:#F7931A; }
        .chip-usdt { background:rgba(38,161,123,.12); color:#26A17B; }
        .chip-owner { background:rgba(254,210,85,.25); color:#735a00; border:1px solid rgba(254,210,85,.6); }
        .chip-muted { background:#f3ede7; color:#45474a; }
        .pill-gold { background:#C9A227; color:#fff; padding:4px 14px; border-radius:9999px; font-weight:600; font-size:14px; }
        .badge-pos { background:#E8F5E9; color:#2E7D32; }
        .badge-neg { background:#ffdad6; color:#93000a; }

        .alert-success { background:#E8F5E9; color:#2E7D32; border:1px solid #C8E6C9; }
        .alert-info { background:#f9f2ed; color:#45474a; border:1px solid #E8E3D8; }
        .alert-warn { background:#FFF3E0; color:#8a5300; border:1px solid #FFE0B2; }
    </style>
</head>
<body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 bg-surface/95 backdrop-blur border-b border-hairline">
        <nav class="max-w-container mx-auto px-5 md:px-16 h-20 flex items-center justify-between">
            <div class="flex items-center gap-10">
                <a asp-controller="Home" asp-action="Index" class="font-serif text-2xl tracking-tight text-primary">Pínówó</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <div class="hidden md:flex items-center gap-8">
                        <a class="@NavActive("Home")" asp-controller="Home" asp-action="Index">Dashboard</a>
                        <a class="@NavActive("Groups")" asp-controller="Groups" asp-action="Index">Groups</a>
                        <a class="@NavActive("Transactions")" asp-controller="Transactions" asp-action="Index">Transactions</a>
                    </div>
                }
            </div>
            <div class="flex items-center gap-3">
                @if (SignInManager.IsSignedIn(User))
                {
                    var current = await UserManager.GetUserAsync(User);
                    <span class="hidden sm:inline text-sm text-on-surface-variant">Hi, @(current?.Name ?? "user")</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                        <button type="submit" class="btn btn-obsidian btn-sm">Log out</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-ghost" asp-controller="Account" asp-action="Login">Log in</a>
                    <a class="btn btn-gold btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                }
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow w-full">
        <div class="max-w-container mx-auto px-5 md:px-16 py-10 md:py-12">
            @if (TempData["StatusMessage"] is string status)
            {
                <div id="status-banner" class="alert-success rounded-xl px-4 py-3 mb-8 flex items-center justify-between">
                    <span class="flex items-center gap-2 flex-wrap">
                        <span class="material-symbols-outlined text-[18px]">check_circle</span>@status
                        @if (TempData["TxUrl"] is string txUrl)
                        {
                            <a href="@txUrl" target="_blank" rel="noopener" class="inline-flex items-center gap-1 underline font-medium text-gold">
                                View transaction on Etherscan
                                <span class="material-symbols-outlined text-[16px]">open_in_new</span>
                            </a>
                        }
                    </span>
                    <button type="button" onclick="document.getElementById('status-banner').remove()" class="material-symbols-outlined text-[18px] cursor-pointer opacity-70 hover:opacity-100">close</button>
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="border-t border-hairline bg-surface-low mt-auto">
        <div class="max-w-container mx-auto px-5 md:px-16 py-10 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex flex-col items-center md:items-start gap-1">
                <span class="font-serif text-xl text-primary">Pínówó</span>
                <p class="text-xs text-on-surface-variant">Crypto-denominated expense splitting.</p>
            </div>
            <p class="text-xs text-on-surface-variant">&copy; @DateTime.UtcNow.Year Pínówó. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

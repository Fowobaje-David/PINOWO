@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="max-w-[440px] mx-auto">
    <div class="flex flex-col items-center text-center mb-8">
        <svg width="44" height="44" viewBox="0 0 40 40" fill="none" class="mb-3">
            <circle cx="20" cy="20" r="18" stroke="#C9A227" stroke-width="2.5" />
            <path d="M20 2V38" stroke="#C9A227" stroke-width="2.5" stroke-linecap="round" />
            <path d="M38 20H2" stroke="#C9A227" stroke-width="2.5" stroke-linecap="round" opacity="0.3" />
            <path d="M20 20L32.7 7.3" stroke="#C9A227" stroke-width="2.5" stroke-linecap="round" />
        </svg>
        <h1 class="font-serif text-3xl text-primary">Pínówó</h1>
    </div>

    <div class="card p-8">
        <div class="mb-6">
            <h2 class="font-serif text-2xl text-primary">Create your account</h2>
            <p class="text-on-surface-variant mt-1 text-sm">Start splitting crypto-denominated expenses with your group.</p>
        </div>

        <form asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly"></div>

            <div>
                <label asp-for="Name" class="field-label"></label>
                <input asp-for="Name" class="field" autocomplete="name" placeholder="e.g. Amara Okafor" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
            <div>
                <label asp-for="Email" class="field-label"></label>
                <input asp-for="Email" class="field" autocomplete="email" placeholder="you@pinowo.demo" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div>
                <label asp-for="Password" class="field-label"></label>
                <input asp-for="Password" class="field" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>
            <div>
                <label asp-for="ConfirmPassword" class="field-label"></label>
                <input asp-for="ConfirmPassword" class="field" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-gold w-full">Register</button>
        </form>

        <div class="mt-6 pt-5 border-t border-hairline text-center text-sm text-on-surface-variant">
            Already have an account? <a asp-action="Login" class="text-gold font-semibold hover:underline underline-offset-4">Log in</a>
        </div>
    </div>
</div>
